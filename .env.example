# Copy to .env and fill in values
#
# ---------------------------------------------------------------------------
# WHERE WILL YOU RUN "npm run dev" ?
#
# • GitHub Codespaces (repo in BROWSER → Code → Codespaces):
#     DATABASE_URL must use host  postgres
#     REDIS_URL must be            redis://redis:6379
#
# • Your own Windows PC (black CMD / PowerShell on Desktop):
#     DATABASE_URL must use host  localhost   (and you need Postgres+Redis installed — see README)
#     REDIS_URL must be            redis://localhost:6379
#
# Using "postgres" on your home PC will ALWAYS fail. That was the mix-up.
# ---------------------------------------------------------------------------

NODE_ENV=production



# PostgreSQL — default below is for GitHub Codespaces / Docker. On your PC use localhost (see top).

DATABASE_URL=postgresql://ogmp:ogmp@postgres:5432/ogmp_mm?schema=public



REDIS_URL=redis://redis:6379



# Main escrow bot token (preferred). TELEGRAM_BOT_TOKEN is accepted as a legacy alias.

MAIN_BOT_TOKEN=

TELEGRAM_BOT_TOKEN=



# OGMP MM REPORT bot — separate @BotFather token for dispute intake

OGMP_MM_REPORT_BOT_TOKEN=



# Comma-separated numeric Telegram user IDs (admins). ADMIN_TELEGRAM_IDS is merged.

ADMIN_IDS=

ADMIN_TELEGRAM_IDS=



# Optional @username (no @) — main bot handle for t.me links (invites, REPORT bot “Start Case”).

BOT_PUBLIC_USERNAME=

REPORT_BOT_USERNAME=



SERVER_PORT=8080



# mock | nowpayments — use mock for local/dev until provider keys exist

PAYMENT_PROVIDER=mock



NOWPAYMENTS_API_KEY=

NOWPAYMENTS_IPN_SECRET=

# Optional — defaults to https://api.nowpayments.io

NOWPAYMENTS_API_BASE=

PUBLIC_BASE_URL=https://your-domain.example



MOCK_WEBHOOK_SECRET=change_me_to_a_long_random_string



AUTO_RELEASE_ENABLED=false

# When true (default), after payment confirms the main bot DMs each delivery file to the buyer automatically.
# When false, the buyer gets a "Download Files" button instead.
AUTO_SEND_DELIVERY_AFTER_PAYMENT=true



# ---------------------------------------------------------------------------
# OGMP Gateway (mandatory community step before using the escrow bot)
# ---------------------------------------------------------------------------
# When REQUIRE_GATEWAY_JOIN is true, users see the gateway screen on /start and must tap Continue.
# Set GATEWAY_CHAT_ID to a channel/supergroup id (e.g. -100…) so the bot can verify membership via getChatMember
# (the bot must be admin there). Leave empty to use honor-system on Continue.
# Admins can override join URL, label, chat id, and requirement from Admin → Gateway settings.

REQUIRE_GATEWAY_JOIN=true

GATEWAY_JOIN_URL=https://t.me/OGMP_GatewayBot

GATEWAY_USERNAME=@OGMP_GatewayBot

GATEWAY_CHAT_ID=



# Report deep-link session lifetime (minutes)

REPORT_SESSION_EXPIRY_MINUTES=60



# File safety (Telegram limits still apply)

MAX_UPLOAD_SIZE_MB=50

BLOCKED_FILE_EXTENSIONS=.exe,.bat,.cmd,.scr,.js,.vbs,.ps1,.jar



SUPPORT_USERNAME=

# Used by OGMP MM REPORT home screen “Start Case” button (Telegram @handle without @).

BOT_PUBLIC_USERNAME=


# Optional fee overrides (otherwise DB FeeSetting row is used)

PLATFORM_FEE_PERCENT=

MIN_FEE=

MAX_FEE=



# Run BullMQ worker in the same process as the API/bots (set false if you run a dedicated worker)

NOTIFICATION_WORKER_ENABLED=true



RATE_LIMIT_WINDOW_MS=10000

RATE_LIMIT_MAX=30



LOG_LEVEL=info



WEBHOOK_SECRET=

APP_SECRET_KEY=

