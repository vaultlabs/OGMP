{
  "name": "OGMP MM (browser / cloud)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { "label": "HTTP health + webhooks" }
  },
  "postCreateCommand": "npm install && npm run db:setup",
  "postStartCommand": "npx prisma migrate deploy",
  "customizations": {
    "vscode": {
      "extensions": ["Prisma.prisma", "dbaeumer.vscode-eslint"]
    }
  }
}
